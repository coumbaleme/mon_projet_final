{% extends 'base.html.twig' %}

{% block title %}Product
{% endblock %}

{% block body %}
	<h1>Product</h1>

	<table class="table table-striped">
		<thead>
			<tr>
				<th>Id</th>
				<th>Prix</th>
				<th>Titre</th>
				<th>Description</th>
				<th>Image</th>
			</tr>
		</thead>
		<tbody>
			<tr>
				<td>{{ product.id }}</td>
				<td>{{ product.prix }}</td>
				<td>{{ product.titre }}</td>
				<td>{{ product.description }}</td>
				<td>
					<img style="width:50px" src="{{ asset('images/product_image/' ~ product.image) }}">
				</td>
			</tr>
		</tbody>
	</table>

	<a href="{{ path('product_index') }}">Retour à la liste</a>

	<a href="{{ path('product_edit', {'id': product.id}) }}">Modifier</a>

	{{ include('product/_delete_form.html.twig') }}
{% endblock %}
