{% extends 'base.html.twig' %}

{% block title %}list des Product {% endblock %}

{% block body %}
    <h1>List des Product</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Titre</th>
                <th>Prix</th>
                <th>Description</th>
                <th>Image</th>
                <th>actions</th>
                  <th>stock</th>
                  <th>suprimer </th>
            </tr>
        </thead>
        <tbody>
        {% for product in pror %}
            <tr>
                <td>{{ product.id }}</td>
                <td>{{ product.titre }}</td>
                <td>{{ product.prix }}</td>
                <td>{{ product.description }}</td>
                <td><img style="width: 30px; height: 30px;" src="{{ asset('images/product_image/' ~ product.image) }}" alt=""></td>
                <td>
                    <a href="{{ path('app_product_show', {'id': product.id}) }}">Afficher</a>
                    <a href="{{ path('product_edit', {'id': product.id}) }}">Modifier</a>
                    <td>{{ product.stock }}</td>
                </td>
                <td>
                    {{ include('product/_delete_form.html.twig') }}
                    
            </tr>
        {% else %}
            <tr>
                <td colspan="5">aucun enregistrement trouvé</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_product_new') }}">Creer Nouveau</a>
{% endblock %}
