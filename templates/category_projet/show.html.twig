{% extends 'base.html.twig' %}

{% block title %}CategoryProjet{% endblock %}

{% block body %}
    <h1>CategoryProjet</h1>
    <table class="table table-striped"><thead>
        <tr>
            <th>Id</th> 
            <th>Nom</th>
            <th>Description</th>
            <th>Image</th>
        </tr>
    </thead>

    <tbody>
        <tr>
            <td>{{ category_projet.id }}</td>
            <td>{{ category_projet.nom }}</td>
            <td>{{ category_projet.description }}</td>
            <td>
                <img style="width:100px; height:60px;"
                     src="{{ asset('images/projet/' ~ category_projet.image) }}"
                     alt="">
            </td>
        </tr>
    </tbody>
</table>
    <a href="{{ path('app_category_projet_index') }}">Retour à la liste</a>

    <a href="{{ path('app_category_projet_edit', {'id': category_projet.id}) }}">Modifier</a>

    {{ include('category_projet/_delete_form.html.twig') }}
{% endblock %}
