{% extends 'base.html.twig' %}

{% block title %}CategoryTraveaux{% endblock %}


{% block body %}
    <h1>CategoryTraveaux</h1>

      <table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th> 
            <th>Nom</th>
            <th>Description</th>
            <th>Image</th>
        </tr>
    </thead>

    <tbody>
        <tr>
            <td>{{ category_traveaux.id }}</td>
            <td>{{ category_traveaux.name }}</td>
            <td>{{ category_traveaux.description }}</td>
            <td>

                <img style="width:100px; height:60px;"
                     src="{{ asset('images/product_image/' ~ category_traveaux.image) }}" alt="">

                   
                    
            </td>
        </tr>
    </tbody>
</table>

    <a href="{{ path('app_category_traveaux_index') }}">Retour à la liste</a>

    <a href="{{ path('app_category_traveaux_edit', {'id': category_traveaux.id}) }}">Modifier</a>

    {{ include('category_traveaux/_delete_form.html.twig') }}
{% endblock %}
