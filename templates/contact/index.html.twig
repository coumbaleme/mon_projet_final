{% extends 'base.html.twig' %}

{% block title %}Contact{% endblock %}

{% block body %}
<div class="container py-5" style="background-color: #f8f9fa; border-radius: 10px;">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <h1 class="mb-4 text-center">Contactez-nous</h1>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success">
                    {{ message }}
                </div>
            {% endfor %}

            {{ form_start(form) }}

            <div class="mb-3">
                {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                <div class="text-danger">
                    {{ form_errors(form.nom) }}
                </div>
            </div>

            <div class="mb-3">
                {{ form_label(form.email, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                <div class="text-danger">
                    {{ form_errors(form.email) }}
                </div>
            </div>

            <div class="mb-3">
                {{ form_label(form.message, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.message, {'attr': {'class': 'form-control', 'rows': '5'}}) }}
                <div class="text-danger">
                    {{ form_errors(form.message) }}
                </div>
            </div>

          
            {{ form_end(form) }}

        </div>
    </div>
</div>
{% endblock %}