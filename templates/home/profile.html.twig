{% extends 'base.html.twig' %}
 
{% block title %}Mon Profil{% endblock %}
 
{% block body %}
<div class="container mt-4">
 
    <h1 class="mb-3">Profil utilisateur</h1>
 
    <div class="card p-3 mb-4">
        <p><strong>Email :</strong> {{ app.user.email }}</p>
        <p><strong>Nom d'utilisateur :</strong> {{ app.user.username }}</p>
    </div>
 
    <h2 class="mt-4">Mes Commandes</h2>
 
    <p>{{ resultat }}</p>
 
    {% if commandes is not empty %}
        <table class="table table-striped mt-3">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Paiement</th>
                 
                </tr>
            </thead>
            <tbody>
            {% for item in commandes %}
                <tr>
                    <td>{{ item.id }}</td>
                    <td>{{ item.createdAt ? item.createdAt|date('d/m/Y H:i') : '' }}</td>
                    <td>{{ (item.total / 100) | number_format(2, ',', ' ') }} €</td>
 
                    <!-- Paiement -->
                   <td>
    {% if item.status == 'paid' %}
        <span class="badge bg-success">Payée</span>
    {% elseif item.status == 'pending' %}
        <span class="badge bg-warning text-dark">En attente</span>
    {% elseif item.status == 'canceled' %}
        <span class="badge bg-danger">Annulée</span>
    {% else %}
        <span class="badge bg-secondary">{{ item.status }}</span>
    {% endif %}
</td>
<td>
    {% if item.status == 'confirmed' %}
        <span class="badge bg-primary">Confirmée</span>
    {% elseif item.status == 'paid' %}
        <span class="badge bg-info text-dark">Payée</span>
    {% else %}
        <span class="badge bg-warning text-dark">Non confirmée</span>
    {% endif %}
</td>
                </tr>
 
                {% if item.items is not empty %}
                    {% for orderItem in item.items %}
                        <tr>
                            <td colspan="5">
                                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                                    <div>
                                        <strong>{{ orderItem.productName }}</strong>
                                        <span class="text-muted">x{{ orderItem.quantity }}</span>
                                        <span class="ms-2">
                                            {{ (orderItem.unitPrice / 100) | number_format(2, ',', ' ') }} €
                                        </span>
                                    </div>
 
                                    <div>
                                        {% if orderItem.product %}
                                            <form method="post" action="{{ path('cart_add', {'id': orderItem.product.id}) }}" class="d-inline">
                                                <input type="hidden" name="quantity" value="1">
                                                <button type="submit" class="btn btn-sm btn-outline-primary">Recommander</button>
                                            </form>
                                        {% else %}
                                            <span class="text-muted">Produit supprimé</span>
                                        {% endif %}
                                    </div>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                {% endif %}
            {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>Aucune commande pour le moment.</p>
    {% endif %}
</div>
{% endblock %}
 
 