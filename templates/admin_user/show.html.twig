{% extends 'base.html.twig' %}

{% block title %}AdminUserController{% endblock %}

{% block body %}
    <h1>AdminUserController</h1>
    
    <table class="table table-striped">
        <tbody>
            <tr>
                <th>Id</th>
                
                <td>{{ user.id }}</td>
            </tr>
            <tr>
                <th>E-mail</th>
                <td>{{ user.email }}</td>
            </tr>
            
            <tr>
                <th>Roles</th>
                <td>{{ user.roles ? user.roles|json_encode : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_admin_user_index') }}">Retour à la liste</a>

    <a href="{{ path('app_admin_user_edit', {'id': user.id}) }}">Modifier</a>

    {{ include('admin_user/_delete_form.html.twig') }}
{% endblock %}
