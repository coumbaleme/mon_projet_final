{% extends 'base.html.twig' %}

{% block title %}CategoryMetier{% endblock %}

{% block body %}
    <h1>CategoryMetier</h1>

       <table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th> 
            <th>Nom</th>
            <th>Description</th>
            <th>Image</th>
        </tr>
    </thead>

    <tbody>
        <tr>
            <td>{{ category_metier.id }}</td>
            <td>{{ category_metier.nom }}</td>
            <td>{{ category_metier.description }}</td>
            <td>
                <img style="width:100px; height:60px;"
                     src="{{ asset('images/metiers/' ~ category_metier.image) }}"
                     alt="">
            </td>
        </tr>
    </tbody>
</table>

    <a href="{{ path('app_category_metier_index') }}">Retour à la liste</a>

    <a href="{{ path('app_category_metier_edit', {'id': category_metier.id}) }}">Modifier</a>

    {{ include('category_metier/_delete_form.html.twig') }}
{% endblock %}
